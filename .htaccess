# HTTP response headers
<IfModule mod_headers.c>
  # HSTS — set unconditionally: TLS is terminated at the CDN (StackCDN), so the
  # origin Apache sees the request as HTTP and a %{HTTPS}=='on' guard would never
  # fire. The browser↔CDN leg is always HTTPS, which is the connection HSTS protects.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content Security Policy — restricts script/style/connect to known sources.
  #   script-src 'self'      → only script.js (JSON-LD blocks are non-executable, not covered)
  #   style-src              → styles.css + Google Fonts stylesheet
  #   font-src               → Google Fonts files
  #   img-src 'self' data:   → assets/*.jpg + inline SVG favicon
  #   connect-src            → contact form fetch() to Formspree
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; base-uri 'self'; object-src 'none'; frame-ancestors 'none'"
</IfModule>

# Serve Markdown (llms.txt page versions) as readable UTF-8 text, not a download
<IfModule mod_mime.c>
  AddType text/markdown .md
  AddCharset utf-8 .md
</IfModule>

# Clean URLs — serve .html pages without the extension
<IfModule mod_rewrite.c>
  RewriteEngine On

  # /index or /index.html  ->  /   (301)
  RewriteCond %{THE_REQUEST} \s/+index(?:\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # /page.html  ->  /page   (301)
  RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # Internally serve /page from page.html (no redirect)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
